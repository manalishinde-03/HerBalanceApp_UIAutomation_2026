<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="HerBalance" parallel="tests" thread-count="1">
<listeners>
		<listener class-name="utilities.Transformer" />
	</listeners> 
 	<test name="FirefoxTests" >
		<parameter name="browserType" value="firefox" />
		<parameter name="cucumber.filters.tags" value="@TC1"></parameter>
		<classes>
			<class name="testRunner.Runner" />
		</classes>
	</test>
	
	<test name="EdgeTests">
		<parameter name="browserType" value="edge" />
		<classes>
			<class name="testRunner.Runner" />
		</classes>
	</test>  

	<test name="ChromeTests">
		<parameter name="browserType" value="chrome" />
		<classes>
			<class name="testRunner.Runner" />
		</classes>
	</test>
	
	
</suite>